# --- Ethereum Sepolia deploy (copy to .env and fill it; .env is gitignored) ---

# drpc serves eth_getLogs (the frontend needs it); many free RPCs don't.
SEPOLIA_RPC=https://sepolia.drpc.org

# Deployer key. Use a THROWAWAY / dev wallet — NEVER your main account.
DEPLOYER_PRIVATE_KEY=

# Optional: only needed to verify the source on Etherscan (free key at etherscan.io).
ETHERSCAN_API_KEY=
